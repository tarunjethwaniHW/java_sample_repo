# Stop searching parent directories for lombok.config
config.stopBubbling = true

# Add @Generated annotation to generated code
lombok.addLombokGeneratedAnnotation = true

# Use fluent accessors
lombok.accessors.chain = true
lombok.accessors.fluent = false

# Default field access level
lombok.fieldDefaults.defaultPrivate = true
lombok.fieldDefaults.defaultFinal = false

# Constructor behavior
lombok.anyConstructor.suppressConstructorProperties = true

# Logging
lombok.log.fieldName = log

# Equals and HashCode
lombok.equalsAndHashCode.callSuper = call

# ToString settings
lombok.toString.callSuper = call

# Builder settings
lombok.builder.className = Builder
lombok.superBuilder.flagUsage = warning

# Prevent @Data usage in favor of fine-grained annotations (best practice)
lombok.data.flagUsage = warning

# Getter/Setter usage control
lombok.getter.flagUsage = warning
lombok.setter.flagUsage = warning

# Non-null handling
lombok.nonNull.exceptionType = IllegalArgumentException

# Add @ConstructorProperties to generated constructors
lombok.anyConstructor.addConstructorProperties = true

# Strict quality rules
lombok.var.flagUsage = error
lombok.val.flagUsage = warning
